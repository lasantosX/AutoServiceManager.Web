@model AutoServiceManager.Web.Models.Vehicle

@{
    ViewData["Title"] = "Delete Vehicle";
}

<h1>Delete Vehicle</h1>

<div class="alert alert-warning">
    Are you sure you want to delete this vehicle?
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Vehicle</dt>
            <dd class="col-sm-9">@Model.DisplayName</dd>

            <dt class="col-sm-3">VIN</dt>
            <dd class="col-sm-9">@Model.Vin</dd>

            <dt class="col-sm-3">License Plate</dt>
            <dd class="col-sm-9">@Model.LicensePlate</dd>

            <dt class="col-sm-3">Customer</dt>
            <dd class="col-sm-9">@Model.Customer?.FullName</dd>
        </dl>

        <form asp-action="Delete" method="post" class="d-flex justify-content-end gap-2">
            <input type="hidden" asp-for="Id" />

            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            <button type="submit" class="btn btn-danger">Delete Vehicle</button>
        </form>
    </div>
</div>