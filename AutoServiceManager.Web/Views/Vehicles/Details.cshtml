@model AutoServiceManager.Web.Models.Vehicle

@{
    ViewData["Title"] = "Vehicle Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>@Model.DisplayName</h1>
        <p class="text-muted mb-0">Vehicle details and related service history.</p>
    </div>

    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header">
        Vehicle Information
    </div>

    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Customer</dt>
            <dd class="col-sm-9">@Model.Customer?.FullName</dd>

            <dt class="col-sm-3">VIN</dt>
            <dd class="col-sm-9">@Model.Vin</dd>

            <dt class="col-sm-3">Year</dt>
            <dd class="col-sm-9">@Model.Year</dd>

            <dt class="col-sm-3">Make</dt>
            <dd class="col-sm-9">@Model.Make</dd>

            <dt class="col-sm-3">Model</dt>
            <dd class="col-sm-9">@Model.Model</dd>

            <dt class="col-sm-3">License Plate</dt>
            <dd class="col-sm-9">@Model.LicensePlate</dd>

            <dt class="col-sm-3">Created</dt>
            <dd class="col-sm-9">@Model.RowCreatedDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>

            <dt class="col-sm-3">Modified</dt>
            <dd class="col-sm-9">
                @(Model.RowModifiedDate.HasValue
                    ? Model.RowModifiedDate.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                    : "Not modified")
            </dd>
        </dl>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header">
        Service Orders
    </div>

    <div class="card-body">
        @if (!Model.ServiceOrders.Any())
        {
            <p class="text-muted mb-0">No service orders created for this vehicle.</p>
        }
        else
        {
            <ul class="list-group list-group-flush">
                @foreach (var serviceOrder in Model.ServiceOrders)
                {
                    <li class="list-group-item">
                        RO #@serviceOrder.Id - @serviceOrder.Status - @serviceOrder.GrandTotal.ToString("C")
                    </li>
                }
            </ul>
        }
    </div>
</div>