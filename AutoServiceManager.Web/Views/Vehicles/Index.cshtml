@model IEnumerable<AutoServiceManager.Web.Models.Vehicle>

@{
    ViewData["Title"] = "Vehicles";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-0">Vehicles</h1>
        <p class="text-muted mb-0">Manage vehicles assigned to customers.</p>
    </div>

    <a asp-action="Create" class="btn btn-primary">Add Vehicle</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form asp-action="Index" method="get" class="row g-2 mb-3">
    <div class="col-md-10">
        <input type="text"
               name="searchTerm"
               value="@ViewData["CurrentFilter"]"
               class="form-control"
               placeholder="Search by VIN, make, model, plate, or customer..." />
    </div>

    <div class="col-md-2 d-grid">
        <button type="submit" class="btn btn-outline-secondary">Search</button>
    </div>
</form>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Vehicle</th>
                    <th>VIN</th>
                    <th>License Plate</th>
                    <th>Customer</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            No vehicles found.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var vehicle in Model)
                    {
                        <tr>
                            <td>@vehicle.DisplayName</td>
                            <td>@vehicle.Vin</td>
                            <td>@vehicle.LicensePlate</td>
                            <td>@vehicle.Customer?.FullName</td>
                            <td>@vehicle.RowCreatedDate.ToLocalTime().ToString("yyyy-MM-dd")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@vehicle.Id" class="btn btn-sm btn-outline-info">Details</a>
                                <a asp-action="Edit" asp-route-id="@vehicle.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@vehicle.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>