@model AutoServiceManager.Web.Models.ServiceOrder

@{
    ViewData["Title"] = "Service Order Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>RO #@Model.Id</h1>
        <p class="text-muted mb-0">Service order details, vehicle, technician, and operations.</p>
    </div>

    <div>
        <a asp-controller="Operations" asp-action="Create" asp-route-serviceOrderId="@Model.Id" class="btn btn-primary">Add Operation</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-8">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                Service Order Information
            </div>

            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Customer</dt>
                    <dd class="col-sm-9">@Model.Customer?.FullName</dd>

                    <dt class="col-sm-3">Vehicle</dt>
                    <dd class="col-sm-9">@Model.Vehicle?.DisplayName</dd>

                    <dt class="col-sm-3">VIN</dt>
                    <dd class="col-sm-9">@Model.Vehicle?.Vin</dd>

                    <dt class="col-sm-3">Technician</dt>
                    <dd class="col-sm-9">@(Model.Technician?.FullName ?? "Unassigned")</dd>

                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">
                        <span class="badge bg-primary">@Model.Status</span>
                    </dd>

                    <dt class="col-sm-3">Complaint</dt>
                    <dd class="col-sm-9">@Model.Complaint</dd>

                    <dt class="col-sm-3">Opened</dt>
                    <dd class="col-sm-9">@Model.OpenedDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>

                    <dt class="col-sm-3">Closed</dt>
                    <dd class="col-sm-9">
                        @(Model.ClosedDate.HasValue
                            ? Model.ClosedDate.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                            : "Not closed")
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                Totals
            </div>

            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span>Labor Total</span>
                    <strong>@Model.LaborTotal.ToString("C")</strong>
                </div>

                <div class="d-flex justify-content-between mb-2">
                    <span>Parts Total</span>
                    <strong>@Model.PartsTotal.ToString("C")</strong>
                </div>

                <hr />

                <div class="d-flex justify-content-between fs-5">
                    <span>Grand Total</span>
                    <strong>@Model.GrandTotal.ToString("C")</strong>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Operations</span>
        <a asp-controller="Operations" asp-action="Create" asp-route-serviceOrderId="@Model.Id" class="btn btn-sm btn-primary">Add Operation</a>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Description</th>
                    <th>Labor Hours</th>
                    <th>Labor Rate</th>
                    <th>Labor Amount</th>
                    <th>Parts</th>
                    <th>Total</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Operations.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            No operations added yet.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var operation in Model.Operations)
                    {
                        <tr>
                            <td>@operation.Description</td>
                            <td>@operation.LaborHours</td>
                            <td>@operation.LaborRate.ToString("C")</td>
                            <td>@operation.LaborAmount.ToString("C")</td>
                            <td>@operation.PartsAmount.ToString("C")</td>
                            <td>@operation.TotalAmount.ToString("C")</td>
                            <td class="text-end">
                                <a asp-controller="Operations" asp-action="Edit" asp-route-id="@operation.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                                <a asp-controller="Operations" asp-action="Delete" asp-route-id="@operation.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>