@model AutoServiceManager.Web.Models.ServiceOrder

@{
    ViewData["Title"] = "Edit Service Order";
}

<h1>Edit Service Order</h1>
<p class="text-muted">Update service order assignment and status.</p>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="CustomerId" class="form-label"></label>
                    <select asp-for="CustomerId" class="form-select" asp-items="ViewBag.CustomerId">
                        <option value="">-- Select Customer --</option>
                    </select>
                    <span asp-validation-for="CustomerId" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="VehicleId" class="form-label"></label>
                    <select asp-for="VehicleId" class="form-select" asp-items="ViewBag.VehicleId">
                        <option value="">-- Select Vehicle --</option>
                    </select>
                    <span asp-validation-for="VehicleId" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="TechnicianId" class="form-label"></label>
                    <select asp-for="TechnicianId" class="form-select" asp-items="ViewBag.TechnicianId">
                        <option value="">-- Unassigned --</option>
                    </select>
                    <span asp-validation-for="TechnicianId" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<AutoServiceManager.Web.Models.ServiceOrderStatus>()"></select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>

                <div class="col-md-12 mb-3">
                    <label asp-for="Complaint" class="form-label"></label>
                    <input asp-for="Complaint" class="form-control" />
                    <span asp-validation-for="Complaint" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="LaborTotal" class="form-label"></label>
                    <input asp-for="LaborTotal" class="form-control" readonly />
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="PartsTotal" class="form-label"></label>
                    <input asp-for="PartsTotal" class="form-control" readonly />
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="GrandTotal" class="form-label"></label>
                    <input asp-for="GrandTotal" class="form-control" readonly />
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}