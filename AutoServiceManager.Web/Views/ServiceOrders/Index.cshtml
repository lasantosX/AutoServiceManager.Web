@model IEnumerable<AutoServiceManager.Web.Models.ServiceOrder>

@{
    ViewData["Title"] = "Service Orders";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-0">Service Orders</h1>
        <p class="text-muted mb-0">Manage repair orders, assigned vehicles, technicians, and totals.</p>
    </div>

    <a asp-action="Create" class="btn btn-primary">Create Service Order</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form asp-action="Index" method="get" class="row g-2 mb-3">
    <div class="col-md-10">
        <input type="text"
               name="searchTerm"
               value="@ViewData["CurrentFilter"]"
               class="form-control"
               placeholder="Search by RO number, customer, vehicle, technician, or status..." />
    </div>

    <div class="col-md-2 d-grid">
        <button type="submit" class="btn btn-outline-secondary">Search</button>
    </div>
</form>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>RO #</th>
                    <th>Customer</th>
                    <th>Vehicle</th>
                    <th>Technician</th>
                    <th>Status</th>
                    <th>Opened</th>
                    <th>Total</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            No service orders found.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var serviceOrder in Model)
                    {
                        <tr>
                            <td>RO #@serviceOrder.Id</td>
                            <td>@serviceOrder.Customer?.FullName</td>
                            <td>@serviceOrder.Vehicle?.DisplayName</td>
                            <td>@serviceOrder.Technician?.FullName</td>
                            <td>
                                <span class="badge bg-primary">@serviceOrder.Status</span>
                            </td>
                            <td>@serviceOrder.OpenedDate.ToLocalTime().ToString("yyyy-MM-dd")</td>
                            <td>@serviceOrder.GrandTotal.ToString("C")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@serviceOrder.Id" class="btn btn-sm btn-outline-info">Details</a>
                                <a asp-action="Edit" asp-route-id="@serviceOrder.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@serviceOrder.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>