@model AutoServiceManager.Web.Models.ServiceOrder

@{
    ViewData["Title"] = "Delete Service Order";
}

<h1>Delete Service Order</h1>

<div class="alert alert-warning">
    Are you sure you want to delete this service order?
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">RO #</dt>
            <dd class="col-sm-9">@Model.Id</dd>

            <dt class="col-sm-3">Customer</dt>
            <dd class="col-sm-9">@Model.Customer?.FullName</dd>

            <dt class="col-sm-3">Vehicle</dt>
            <dd class="col-sm-9">@Model.Vehicle?.DisplayName</dd>

            <dt class="col-sm-3">Technician</dt>
            <dd class="col-sm-9">@(Model.Technician?.FullName ?? "Unassigned")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>

            <dt class="col-sm-3">Operations</dt>
            <dd class="col-sm-9">@Model.Operations.Count</dd>

            <dt class="col-sm-3">Grand Total</dt>
            <dd class="col-sm-9">@Model.GrandTotal.ToString("C")</dd>
        </dl>

        <form asp-action="Delete" method="post" class="d-flex justify-content-end gap-2">
            <input type="hidden" asp-for="Id" />

            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            <button type="submit" class="btn btn-danger">Delete Service Order</button>
        </form>
    </div>
</div>