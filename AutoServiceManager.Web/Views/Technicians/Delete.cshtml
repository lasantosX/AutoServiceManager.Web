@model AutoServiceManager.Web.Models.Technician

@{
    ViewData["Title"] = "Delete Technician";
}

<h1>Delete Technician</h1>

<div class="alert alert-warning">
    Are you sure you want to delete this technician?
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.FullName</dd>

            <dt class="col-sm-3">Specialty</dt>
            <dd class="col-sm-9">@Model.Specialty</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @(Model.IsActive ? "Active" : "Inactive")
            </dd>
        </dl>

        <form asp-action="Delete" method="post" class="d-flex justify-content-end gap-2">
            <input type="hidden" asp-for="Id" />

            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            <button type="submit" class="btn btn-danger">Delete Technician</button>
        </form>
    </div>
</div>